                            <a class="cmn-btn" href="#">
                                Read More
                            </a>

                        </div>

                    </div>
                </div>

                <div class="col-sm-6 col-lg-4">
                    <div class="blog-item">

                        <div class="blog-top">
                            <a href="#">
                                <img src="{{ asset('assets/img/home-one/blog2.jpg') }}" alt="Blog">
                            </a>

                            <span>02 May 2024</span>
                        </div>

                        <div class="blog-bottom">

                            <h3>
                                <a href="#">
