{% extends 'base.html.twig' %}

{% block title %}Categories{% endblock %}

{% block body %}

<!-- Page Title -->
<div class="page-title-area page-title-img-one">
    <div class="container">
        <div class="page-title-item">
            <h2>Categories</h2>
            <ul>
                <li><a href="{{ path('home') }}">Home</a></li>
                <li>Categories</li>
            </ul>
        </div>
    </div>
</div>

